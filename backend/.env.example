# Server
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# Database
MONGO_URI=mongodb://127.0.0.1:27017/fundsTransfer

# Redis (BullMQ)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Auth
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=12h

# Encryption (AES-256-GCM). MUST be a 64-char hex string (32 bytes).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KEY_ENCRYPTION_SECRET=

# BNB Smart Chain
# Mainnet (chainId 56)
BSC_CHAIN_ID=56
BSC_RPC_HTTP=https://bsc-dataseed.bnbchain.org
BSC_RPC_HTTP_BACKUPS=https://bsc-dataseed1.defibit.io,https://bsc-dataseed1.ninicoin.io
BSC_RPC_WS=wss://bsc-rpc.publicnode.com
#
# Testnet (chainId 97) — uncomment for testing
# BSC_CHAIN_ID=97
# BSC_RPC_HTTP=https://bsc-testnet-rpc.publicnode.com
# BSC_RPC_HTTP_BACKUPS=https://data-seed-prebsc-1-s1.binance.org:8545,https://data-seed-prebsc-2-s1.binance.org:8545
# BSC_RPC_WS=wss://bsc-testnet-rpc.publicnode.com

# Protocol addresses (BSC mainnet)
USDT_BEP20_ADDRESS=0x55d398326f99059fF775485246999027B3197955
STAKING_CONTRACT_ADDRESS=0x73Be7c9CEcB66152f25Aa2e3cb450C61B6Dfc683
# Testnet alternatives:
# USDT_BEP20_ADDRESS=0xf9A59a268CdA3c2677df741B340bD3EFF47567Dc
# STAKING_CONTRACT_ADDRESS=0x3b572bB1a5FC80312f0C53CA22f93F8c7EbdbbF2

# Polling / worker tuning
BALANCE_POLL_INTERVAL_MS=20000
RPC_HEALTH_INTERVAL_MS=30000
WORKER_CONCURRENCY=4

# Speed-up options.
# SWEEP_FAST_MODE=true returns from the sweep worker as soon as the tx is broadcast
# (without waiting for the receipt). A separate reconciler updates the Transfer to
# CONFIRMED/FAILED once mined. Cuts perceived "received → swept" latency by ~3s on BSC.
SWEEP_FAST_MODE=true
# Optional gas price override for sweep transactions, in gwei. Set this slightly
# above the network's current gas price to guarantee inclusion in the next block.
# Leave unset to let the RPC suggest. BSC mainnet typical: 3-5 gwei.
# SWEEP_GAS_PRICE_GWEI=5
# Reconciler poll interval — keep near one block time (BSC ≈ 3000ms).
RECEIPT_RECONCILE_INTERVAL_MS=3000

# Gas top-up sizing.
#   GAS_MODE=fixed     — send wallet.topUpAmount BNB on each top-up (default)
#   GAS_MODE=estimated — estimate the actual cost (gasLimit * gasPrice * (1 + buffer))
#                        for the upcoming tx and send only the deficit. Saves BNB
#                        sitting idle in monitoring/funding wallets.
GAS_MODE=fixed
# Safety buffer applied on top of the gas estimate (percent). Covers gas price
# spikes between estimation and broadcast.
GAS_ESTIMATE_BUFFER_PCT=25
# Floor on a single estimated top-up so we don't broadcast dust txs.
GAS_ESTIMATE_MIN_TOPUP_BNB=0.0001

# CORS
CORS_ORIGIN=http://localhost:5173
